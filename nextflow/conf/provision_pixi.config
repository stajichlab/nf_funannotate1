/*
 * Provisioning: pixi environments (project-local, reproducible).
 *
 * Each label activates a named environment from nextflow/pixi.toml via
 * `pixi shell-hook`, which prints shell code to activate the env; eval-ing it in
 * the beforeScript puts the env's tools on PATH for the process script.
 *
 * Requires the `pixi` binary on PATH (module load pixi, or a user install).
 * NOTE: not all tools install cleanly from conda — funannotate and signalp6-gpu
 * environments are best-effort placeholders (see pixi.toml). Prefer the `module`
 * or `singularity` profile for those until their pixi envs are validated.
 *
 * beforeScripts are double-quoted Groovy strings so ${params.pixi_manifest}
 * resolves at config-parse time; the bash command substitution is escaped (\$(...))
 * so it runs inside the job, not at parse time.
 */

params {
    pixi_manifest = "${projectDir}/pixi.toml"
}

process {
    withLabel: 'funannotate' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment funannotate)"
        """
    }
    withLabel: 'genome_clean' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment genome_clean)"
        """
    }
    withLabel: 'edirect' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment edirect)"
        """
    }
    withLabel: 'sra' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment sra)"
        """
    }
    withLabel: 'antismash' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment antismash)"
        """
    }
    withLabel: 'interproscan' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment interproscan)"
        """
    }
    withLabel: 'signalp' {
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load pixi 2>/dev/null || true
            eval "\$(pixi shell-hook --manifest-path ${params.pixi_manifest} --environment signalp)"
        """
    }
    // 'setup' uses only base system tools (wget/tar/awk) — no pixi env needed.
    withLabel: 'setup' { beforeScript = ':' }
}
