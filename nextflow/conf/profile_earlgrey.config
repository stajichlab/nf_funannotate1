/*
 * earlgrey profile: earlgrey_mask.nf — curated repeat masking of large genomes.
 *
 * EarlGrey + RepeatMasker run from environment modules (loaded inside each process),
 * so no Singularity image is needed.
 *
 * Queue / resource defaults are tuned for the UCR HPCC cluster.
 * Override individual values with --param value or a params-file.
 */

workDir = "${launchDir}/work/earlgrey"

process {

    // De-novo TE discovery + curation on the representative genome — very heavy.
    // Only long-queue partitions (epyc/stajichlab) can host a multi-day EarlGrey run.
    withLabel: 'earlgrey' {
        cpus           = 32
        memory         = '64 GB'
        time           = '7.day'
        clusterOptions = '-N 1 -n 1'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
	    module load earlgrey
	"""

    }

    // Apply the curated library to a conspecific strain — moderate.
    withLabel: 'repeatmask' {
        cpus           = 32
        memory         = '32 GB'
        time           = '8.hr'
        clusterOptions = '-N 1 -n 1'
    }

    // Copy finished masks into input_clean_genomes — trivial I/O.
    withLabel: 'deliver' {
        cpus   = 1
        memory = '2 GB'
        time   = '30 min'
        queue  = 'short'
    }

    // Representative selection — light, pure-Python (stdlib only).
    withLabel: 'select' {
        cpus   = 1
        memory = '4 GB'
        time   = '30 min'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load biopython
        """
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/earlgrey_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/earlgrey_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/earlgrey_timeline.html"
    overwrite = true
}
