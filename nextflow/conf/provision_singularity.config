/*
 * Provisioning: Singularity containers (most portable; same image on HPCC + k8s).
 *
 * `singularity.enabled` is flipped on by the `singularity` profile in
 * nextflow.config; this file maps each process label to a container image.
 * Images are params so they can be overridden on the CLI, e.g.
 *   --container_funannotate /path/to/funannotate.sif
 *
 * Public biocontainers are used where one exists. Tools without a ready image
 * (funannotate, AAFTF, signalp6-gpu, the multi-tool SRA env) point at PLACEHOLDER
 * .sif paths under sif_dir that you build — see comments below.
 *
 * No `beforeScript` is set here: inside the container the tools are already on
 * PATH, so process scripts (which carry no `module load`) run as-is.
 */

params {
    // Directory holding locally-built .sif images.
    sif_dir = '/bigdata/stajichlab/shared/lib/singularity_cache'

    // Public biocontainers (override if you mirror them locally).
    container_edirect      = 'https://depot.galaxyproject.org/singularity/entrez-direct:22.4--he881be0_0'
    container_antismash    = 'https://depot.galaxyproject.org/singularity/antismash-lite:7.1.0--pyhdfd78af_0'
    container_interproscan = 'docker://interpro/interproscan:6.0.0'
    container_setup        = 'https://depot.galaxyproject.org/singularity/gnu-wget:1.18--h36e9172_9'

    // Locally-built images (BUILD THESE). Default to <sif_dir>/<name>.sif.
    container_funannotate  = 'docker://nextgenusfs/funannotate:latest'                       // or build a pinned .sif
    container_genome_clean = '/bigdata/stajichlab/shared/lib/singularity_cache/AAFTF.sif'    // AAFTF + taxonkit + FCS-GX
    container_sra          = '/bigdata/stajichlab/shared/lib/singularity_cache/sra_tools.sif' // sratoolkit+fastp+bbtools+seqkit+aria2
    container_signalp      = '/bigdata/stajichlab/shared/lib/singularity_cache/signalp6-gpu.sif' // licensed; build from tarball
}

process {
    withLabel: 'funannotate'   { container = params.container_funannotate  }
    withLabel: 'genome_clean'  { container = params.container_genome_clean }
    withLabel: 'edirect'       { container = params.container_edirect      }
    withLabel: 'sra'           { container = params.container_sra          }
    withLabel: 'antismash'     { container = params.container_antismash    }
    withLabel: 'interproscan'  { container = params.container_interproscan }
    withLabel: 'signalp'       {
        container        = params.container_signalp
        containerOptions = '--nv'   // GPU passthrough for signalp6-gpu
    }
    withLabel: 'setup'         { container = params.container_setup        }
}
