/*
 * test profile: self-contained synthetic run for `-stub-run`.
 *
 *   nextflow run nextflow/funannotate.nf -c nextflow/nextflow.config -profile test -stub-run
 *   nextflow run nextflow/funannotate.nf -c nextflow/nextflow.config -profile stub -stub-run  (n_test=2)
 *
 * Reuses the annotate params, then overrides paths to tests/data, forces the
 * local executor, disables module/pixi/singularity provisioning (beforeScript=':'
 * per label), and uses tiny resources. The SRA/RNA-seq subgraph is off by default
 * (run_sra_fetch=false) so the stub exercises clean→mask→predict→optional steps;
 * flip --run_sra_fetch true to stub the RNA-seq path too.
 */

includeConfig 'profile_annotate.config'

params {
    samples          = "${projectDir}/tests/data/test_samples.csv"
    source           = "${projectDir}/tests/data/source"
    taxondb          = "${projectDir}/tests/work/taxa"
    funannotate_db   = "${projectDir}/tests/work/funannotate_db"
    suppress         = "${projectDir}/tests/data/suppress.txt"

    target           = "${projectDir}/tests/output/genome_annotation"
    training_target  = "${projectDir}/tests/output/genome_annotation_training"
    rnaseq_data      = "${projectDir}/tests/output/rnaseq_data"

    // exercise the post-predict graph (these fire on a 2nd resumed stub once
    // predict_results/*.gbk exist — single-run semantics match production)
    run_repeatmasker = true
    run_sra_fetch    = false
    run_annotate     = true
    run_antismash    = true
    run_interpro     = true
    run_signalp      = true
    run_update       = false
    pasa_mysql       = false
    n_test           = 0
}

process.executor = 'local'

process {
    // Cap every process to what a login/local node has, regardless of the
    // (larger) per-process requests inherited from profile_annotate's withName
    // blocks — withName outranks withLabel, so resourceLimits is the reliable cap.
    resourceLimits = [ cpus: 2, memory: '2.GB', time: '30.min' ]

    // Disable all tool provisioning for the stub (no module/pixi/singularity);
    // GPU clusterOptions cleared so SIGNALP_RUN can run locally too.
    withLabel: 'setup'        { beforeScript = ':' }
    withLabel: 'genome_clean' { beforeScript = ':' }
    withLabel: 'funannotate'  { beforeScript = ':' }
    withLabel: 'edirect'      { beforeScript = ':' }
    withLabel: 'sra'          { beforeScript = ':' }
    withLabel: 'antismash'    { beforeScript = ':' }
    withLabel: 'interproscan' { beforeScript = ':' }
    withLabel: 'signalp'      { beforeScript = ':'; clusterOptions = '' }
}

workDir = "${projectDir}/tests/work"

trace.enabled    = false
report.enabled   = false
timeline.enabled = false
