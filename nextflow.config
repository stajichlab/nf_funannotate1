/*
 * nf_funannotate1 — eukaryotic genome annotation framework
 *
 * Configuration is split into three ORTHOGONAL profile axes that combine on the
 * command line. Pick one from each axis:
 *
 *   pipeline      : annotate | earlgrey | test
 *   executor      : slurm    | local
 *   provisioning  : ucr_hpcc | pixi  | singularity
 *
 * Provisioning is split into a PORTABLE path and an INSTITUTIONAL path:
 *   - singularity / pixi : portable — runnable at any site; tools come from
 *                          containers or project-local pixi envs.
 *   - ucr_hpcc           : institutional — UCR HPCC Lmod modules. Encodes
 *                          site-specific module names/paths; analogue of an
 *                          nf-core/configs institutional profile.
 *
 * Examples:
 *   -profile annotate,slurm,ucr_hpcc        (default / recommended on UCR HPCC)
 *   -profile annotate,local,singularity     (portable: containers, head local)
 *   -profile annotate,local,ucr_hpcc -stub-run (graph/dry test)
 *
 * The pipeline profile supplies params + per-label resources; the executor
 * profile selects SLURM vs local; the provisioning profile fills each process
 * label's `beforeScript` (ucr_hpcc/pixi) or `container` (singularity). Process
 * scripts themselves are tool-agnostic — they contain NO `module load` lines.
 */

manifest {
    name            = 'nf_funannotate1'
    author          = 'Jason Stajich'
    homePage        = 'https://github.com/stajichlab/nf_funannotate1'
    description     = 'Eukaryotic (fungal-default) genome annotation: clean, mask, RNA-seq train, funannotate predict/annotate/update, antismash/interpro/signalp'
    version         = '0.1.0'
    nextflowVersion = '>=25.10.0'
    // Entry script for `nextflow run stajichlab/nf_funannotate1`.
    // earlgrey_mask.nf is a separate entry; run it with an explicit script path.
    mainScript      = 'funannotate.nf'
}

// Parameter validation + typed --help, driven by nextflow_schema.json (nf-schema).
// Unrecognised params default to warnings (not errors) — earlgrey_mask.nf has its own
// param set and must not hard-fail on this schema.
plugins {
    id 'nf-schema@2.7.2'
}

// NF 26.x passes CLI args as strings; lenientMode lets nf-schema accept "true"/"1"
// where the schema declares boolean/integer — actual Groovy types are already correct.
validation {
    lenientMode    = true
    monochromeLogs = false
}

// ── Shared params (pipeline profiles add their own) ───────────────────────────
params {
    samples    = "${launchDir}/samples.csv"
    n_test     = 0
    // Restrict to a taxonomic group: --taxon RANK:VALUE (e.g. PHYLUM:Ascomycota).
    // Ranks come from samples.csv columns (PHYLUM, SUBPHYLUM, CLASS, ORDER, FAMILY, GENUS).
    taxon      = ''
    // Restrict to a single assembly: --asmid GCA_000001405.15
    asmid      = ''
    // Optional newline/CSV list of ASMIDs to skip.
    suppress   = "${launchDir}/suppress.txt"
    debug      = false
    // GenBank/funannotate locus-tag header length cap. Was a hardcoded constant (24)
    // threaded through the per-sample tuple; promoted to a param ahead of the meta-map
    // conversion (REFACTORING_PLAN.md Principle 0) since it is global, not per-sample.
    header_length = 24
    // --help prints the schema-driven parameter help and exits (see funannotate.nf).
    help       = false
}

// ── Base resource tiers + per-module publishDir (applied before profiles) ─────
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// ── Process defaults (apply to every process, every profile) ──────────────────
process {
    shell          = ['/bin/bash', '-l']
    errorStrategy  = { task.attempt < 3 ? 'retry' : 'finish' }
    maxRetries     = 2
    cache          = 'lenient'   // required for -resume on /bigdata networked FS
    clusterOptions = '-N 1 -n 1'
}

// ── Singularity (off unless the `singularity` provisioning profile is active) ──
singularity {
    enabled      = false
    autoMounts   = true
    cacheDir     = '/bigdata/stajichlab/shared/lib/singularity_cache'
    envWhitelist = 'SCRATCH'
    runOptions   = '--nv'        // expose GPUs when present (no-op without --gres)
}

// ── Profiles (three orthogonal axes + composite test) ─────────────────────────
profiles {

    // ---- executor axis -------------------------------------------------------
    slurm {
        process.executor = 'slurm'
        executor {
            name            = 'slurm'
            queueSize       = 400
            submitRateLimit = '30/1min'
            pollInterval    = '1 min'
            exitReadTimeout = '30 min'
        }
    }
    local {
        process.executor = 'local'
        executor {
            name      = 'local'
            queueSize = 4
        }
    }

    // ---- provisioning axis ---------------------------------------------------
    // Institutional (UCR HPCC Lmod). Portable alternatives: pixi, singularity.
    ucr_hpcc    { includeConfig 'conf/provision_ucr_hpcc.config'    }
    pixi        { includeConfig 'conf/provision_pixi.config'        }
    singularity {
        singularity.enabled = true
        includeConfig 'conf/provision_singularity.config'
    }

    // ---- pipeline axis -------------------------------------------------------
    annotate    { includeConfig 'conf/profile_annotate.config'      }
    earlgrey    { includeConfig 'conf/profile_earlgrey.config'      }

    // ---- test / stub (self-contained: own resources + beforeScript=':') ------
    test        { includeConfig 'conf/test.config'                  }
    stub {
        includeConfig 'conf/test.config'
        params.n_test = 2
    }
}

