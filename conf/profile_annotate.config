/*
 * annotate pipeline profile: funannotate.nf
 *
 * Provides the pipeline params and per-process SLURM resources. Combine with an
 * executor profile (slurm|local) and a provisioning profile (ucr_hpcc|pixi|
 * singularity), e.g.  -profile annotate,slurm,ucr_hpcc
 *
 * Defaults are fungal (busco fungi via BUSCO_LINEAGE column, antismash_taxon=fungi,
 * swissprot_fungi proteins) but every organism-specific value is a param, so other
 * eukaryotes work by override (e.g. --antismash_taxon plants, a different
 * --proteins file, BUSCO_LINEAGE column per row).
 *
 * Adapted from BFD/Fungi_BFD/nextflow/conf/profile_funannotate.config.
 * Change vs source: node-pinning (-w h04,h05,h06) dropped; queues use the skill's
 * partition rules; FUNANNOTATE_TRAIN/SIGNALP queues made explicit.
 */

params {
    // ── inputs / outputs ──────────────────────────────────────────────────────
    target               = "${launchDir}/genome_annotation"
    training_target      = "${launchDir}/genome_annotation_training"
    // NCBI_ASM source dir: genomes resolved as <source>/<ASMID>/<ASMID>_genomic.fna.gz
    // (used only for rows without a GENOME column — see funannotate.nf dual input).
    source               = "/bigdata/stajichlab/shared/projects/1KFG/2026/NCBI_fungi/source/NCBI_ASM"
    taxondb              = "/bigdata/stajichlab/shared/projects/1KFG/2026/NCBI_fungi/tmp/taxa/"
    proteins             = "${launchDir}/lib/swissprot_fungi.faa"
    seqcenter            = "NCBI"

    // ── assembly statistics (for earlgrey_mask.nf SELECT_REPS) ────────────────
    tables_dir           = "${launchDir}/tables"
    gen_asm_stats        = true  // generate asm_stats.tsv.gz from clean genomes
    // Directory ASM_STATS scans for cleaned genomes — the storeDir target that
    // GENOME_CLEAN writes <asmid>.fa into. Must match earlgrey_mask.nf's
    // params.genome_dir so both pipelines read the same cleaned assemblies.
    genome_dir           = "${launchDir}/input_clean_genomes"
    // Writable AUGUSTUS_CONFIG copy, seeded once by SETUP_AUGUSTUS_CONFIG (storeDir-cached).
    // augustus writes new species parameter sets here during training, so it must be a
    // private writable copy of the install's read-only config.
    augustus_config      = "${launchDir}/lib/augustus/3.5/config"
    // Source augustus config to copy from. null = autodetect (AUGUSTUS_CONFIG_PATH from the
    // provisioning env, else ../config from the augustus binary). Override to a specific path
    // to force the seed source.
    augustus_config_source = null
    // Local funannotate database, built once by SETUP_FUNANNOTATE_DB (storeDir-cached).
    // Override to a prebuilt shared DB (e.g. /bigdata/stajichlab/shared/lib/funannotate_db)
    // to skip the build — SETUP_FUNANNOTATE_DB no-ops when this directory already exists.
    funannotate_db       = "${launchDir}/funannotate_db"
    sbt_template         = "${launchDir}/lib/template.sbt"

    // ── genome cleaning / masking ─────────────────────────────────────────────
    min_contig_len       = 2000
    clean_script         = "${projectDir}/scripts/clean_genome_fa.py"
    fcs_shm_script       = "${projectDir}/scripts/setup_fcs_shm.sh"
    // skip_fcs=true bypasses the AAFTF FCS-GX contaminant purge in GENOME_CLEAN
    // (no 470 GB gxdb / highmem needed) — just length-filters the assembly.
    skip_fcs             = false
    // clean_batch_size > 0 batches that many genomes into a single SLURM job that stages
    // the FCS-GX db into /dev/shm once (GENOME_CLEAN_BATCH), amortizing the ~30-min stage.
    // 0 (or skip_fcs) falls back to one SLURM job per genome (GENOME_CLEAN).
    clean_batch_size     = 1000
    run_repeatmasker     = true
    only_clean           = false

    // ── RNA-seq / SRA ─────────────────────────────────────────────────────────
    rnaseq_data          = "${launchDir}/rnaseq_data"
    // Rust helpers built by scripts/build_tools.sh into tools/bin/ (NOT committed).
    fastq_hdr_script     = "${projectDir}/tools/bin/fix_fastq_header_trinity"
    readlen_script       = "${projectDir}/tools/bin/enforce_seqpair_readlen"
    run_sra_fetch        = true
    skip_sra_query       = false
    stop_after_sra_query = false
    stop_after_sra_fetch = false
    sra_query_batch_size = 10
    max_rnaseq_runs      = 2
    max_rnaseq_spot      = 0
    max_rnaseq_reads     = 40000000
    enable_single_end    = false
    max_rnaseq_se_runs   = 3
    rnaseq_trimmer       = "fastp"

    // ── prediction / training ─────────────────────────────────────────────────
    max_cpus             = 64
    max_intronlen        = 3000
    min_intronlen        = 10
    // FUNANNOTATE_PREDICT pre-flight guard: skip assemblies that are BOTH small AND
    // fragmented (they can't yield funannotate's required 30 training models, so predict
    // would run for hours then abort). Skipped genomes are flagged in
    // ${target}/predict_skipped_too_small.tsv. Set predict_min_asm_bp = 0 to disable.
    predict_min_asm_bp       = 8000000    // assembled bp below this = "small"
    predict_frag_max_n50     = 10000      // N50 below this = "fragmented"
    predict_frag_max_contigs = 1000       // contig count above this = "fragmented"

    // ── PASA mysql (mariadb singularity service used by train/update) ──────────
    pasa_mysql           = true
    mariadb_sif          = "/bigdata/stajichlab/shared/lib/mariadb/mariadb.sif"
    mysql_datadir        = "/bigdata/stajichlab/jstajich/mysql/db"
    pasa_conf_dir        = "/rhome/jstajich/.pasa/pasa_conf/"

    // ── optional annotation steps ─────────────────────────────────────────────
    run_update           = false
    run_annotate         = false
    run_antismash        = false
    run_interpro         = false
    run_signalp          = false
    antismash_taxon      = "fungi"
}

workDir = "${launchDir}/work/annotate"
cleanup = false

process {

    withName: 'SETUP_TAXONDB' {
        queue  = 'short'; cpus = 1; memory = '4 GB'; time = '1h'
    }

    withName: 'SETUP_FUNANNOTATE_DB' {
        // Network-bound multi-GB download of BUSCO + all funannotate DBs; needs a
        // long-running queue (short caps at 2h). Runs once, then storeDir-skipped.
        queue  = 'epyc'; cpus = 2; memory = '8 GB'; time = '12h'
    }

    withName: 'SETUP_AUGUSTUS_CONFIG' {
        // Local filesystem copy of the installed augustus config; quick and runs once,
        // then storeDir-skipped.
        queue  = 'short'; cpus = 1; memory = '4 GB'; time = '30m'
    }

    withName: '.*:GENOME_CLEAN' {
        // Full FCS-GX purge needs highmem (stages ~470 GB gx db into /dev/shm);
        // with --skip_fcs it's a light decompress + length-filter.
        queue  = params.skip_fcs ? 'short'   : 'highmem'
        cpus   = params.skip_fcs ? 2         : 16
        memory = params.skip_fcs ? '8 GB'    : '500 GB'
        time   = params.skip_fcs ? '1h'      : '6h'
    }

    withName: '.*:GENOME_CLEAN_BATCH' {
        // Stages the ~470 GB FCS-GX db into /dev/shm once, then cleans up to
        // clean_batch_size genomes sequentially — needs highmem and a long walltime.
        queue  = 'highmem'; cpus = 16; memory = '500 GB'; time = '7d'
    }

    withName: '.*:MASKREPEAT_TANTAN_RUN' {
        queue  = 'short'; cpus = 8; memory = '16 GB'; time = '2h'
    }

    // SRA_QUERY (standalone, not in subworkflow) — matches bare name
    withName: 'SRA_QUERY' {
        queue = 'short'; cpus = 2; memory = '4 GB'; time = '60m'
        maxForks = 10; errorStrategy = 'retry'; maxRetries = 2
    }
    withName: '.*:SRA_QUERY_BATCH' {
        queue = 'short'; cpus = 1; memory = '4 GB'; time = '2h'
        maxForks = 10; errorStrategy = 'retry'; maxRetries = 2
    }
    withName: '.*:COLLECT_SRA_QUERY' {
        queue = 'short'; cpus = 1; memory = '2 GB'; time = '20m'
    }
    withName: '.*:WRITE_EMPTY_READS' {
        queue = 'short'; cpus = 1; memory = '1 GB'; time = '5m'
    }

    withName: '.*:SRA_FETCH' {
        errorStrategy = 'retry'; maxRetries = 3
        queue  = { task.attempt == 1 ? 'short' : 'epyc' }
        memory = { task.attempt == 1 ? '48 GB' : '192 GB' }
        time   = { task.attempt == 1 ? '2h' : task.attempt == 2 ? '8h' : task.attempt == 3 ? '24h' : '48h' }
        cpus   = { task.attempt == 1 ? 24 : 32 }
    }
    withName: '.*:SRA_FETCH_SE' {
        errorStrategy = 'retry'; maxRetries = 3
        queue  = { task.attempt == 1 ? 'short' : 'epyc' }
        memory = { task.attempt == 1 ? '48 GB' : '192 GB' }
        time   = { task.attempt == 1 ? '2h' : task.attempt == 2 ? '8h' : '24h' }
        cpus   = { task.attempt == 1 ? 24 : 32 }
    }

    withName: '.*:RNASEQ_PREPARE' {
        queue  = 'epyc'; cpus = 16
        memory = { task.attempt == 1 ? '52 GB' : (48 + (task.attempt - 1) * 48) + ' GB' }
        time   = '120h'; maxRetries = 3
    }

    withName: '.*:FUNANNOTATE_TRAIN' {
        maxRetries     = 3
        queue          = { task.attempt <= 2 ? 'epyc' : 'highmem' }
        memory         = { task.attempt == 1 ? '48 GB' : task.attempt == 2 ? '192 GB' : '256 GB' }
        time           = { task.attempt == 1 ? '72h' : '120h' }
        cpus           = { task.attempt == 1 ? 8 : 24 }
        clusterOptions = '-N 1 -n 1 --job-name=nf-TRAIN'
    }

    withName: '.*:FUNANNOTATE_PREDICT' {
        queue          = 'epyc'
        memory         = { task.attempt == 1 ? '32 GB' : '64 GB' }
        time           = '72h'
        cpus           = { task.attempt == 1 ? 8 : 16 }
        clusterOptions = '-N 1 -n 1 --job-name=nf-PREDICT'
    }

    withName: 'ANTISMASH_RUN' {
        queue = 'epyc'; cpus = 8; memory = '24 GB'; time = '8h'
    }

    withName: 'INTERPROSCAN_RUN' {
        queue = 'epyc'; cpus = 8; memory = '32 GB'; time = '60h'
    }

    withName: 'SIGNALP_RUN' {
        // signalp6-gpu: GPU partition (gpu allows >2h; short_gpu if always ≤2h).
        queue          = 'gpu'
        cpus           = 16; memory = '64 GB'; time = '8h'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
    }

    withName: 'FUNANNOTATE_ANNOTATE' {
        queue = 'epyc'; cpus = 16; memory = '64 GB'; time = '24h'
    }
    withName: 'FUNANNOTATE_UPDATE' {
        queue = 'epyc'; cpus = 16; memory = '64 GB'; time = '48h'
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/annotate_trace.txt"
    overwrite = true
    fields    = 'task_id,hash,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/annotate_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/annotate_timeline.html"
    overwrite = true
}
